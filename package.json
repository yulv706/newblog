    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^7.0.12",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.5.21",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "~4.0.17",
    "tsx": "^4.19.4",
    "vitest": "^3.1.2"
  }
