{
  "name": "personal-blog",
  "version": "1.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:release": "vitest run src/__tests__/app-version.test.ts src/__tests__/runtime-health.test.ts src/__tests__/docker-deployment.test.ts src/__tests__/layout.test.ts src/__tests__/public-layout-width.test.ts",
    "version:check": "node scripts/check-version.mjs",
    "image:build": "node scripts/build-versioned-image.mjs",
    "preversion": "npm run version:check && npm run typecheck && npm run test:release",
    "version": "npm run version:check",
    "sync:weread": "node scripts/run-migrations.js && node scripts/sync-weread.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/lib/db/seed.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.6",
    "@fontsource/jetbrains-mono": "^5.2.6",
    "better-sqlite3": "^11.9.1",
