AUTH_SECRET=
NEXT_PUBLIC_SITE_URL=
BLOG_MANAGEMENT_API_TOKEN=
BLOG_MANAGEMENT_RATE_LIMIT=120
APP_IMAGE=newblog-app:1.4.0
NGINX_PORT=8080
NGINX_SSL_PORT=8443

# Required for reader email verification codes.
# Port 465 normally uses SMTP_SECURE=true; port 587 normally uses false.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=读写札记 <no-reply@example.com>
SMTP_REPLY_TO=

# Local Mailpit only: start with `docker compose --profile local-mail up -d`.
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=读写札记 <no-reply@local.test>
# MAILPIT_WEB_PORT=8025

# Optional: WeRead official Skill API Key, format wrk-...
WEREAD_API_KEY=
WEREAD_SYNC_PROGRESS_LIMIT=80
WEREAD_SYNC_DETAIL_LIMIT=80
WEREAD_SYNC_HIGHLIGHTS=0
WEREAD_SYNC_HIGHLIGHT_BOOK_LIMIT=30
WEREAD_SYNC_REVIEW_PAGE_LIMIT=3
WEREAD_SYNC_REVIEW_PAGE_SIZE=20
